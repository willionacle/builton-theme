{#
  Full-width featured project card: header bar + image (expands on hover); cursor-follow CTA via JS.
  Expects: title, image_src, href; optional image_alt, cursor_label (default: View project).
  ACF-ready: pass from controller.
#}
{% set cursor_label = cursor_label|default('View project') %}
<section class="featured-project" aria-label="{{ title|default('Featured project')|e }}">
  <a
    class="featured-project__card"
    href="{{ href|default('#') }}"
    data-featured-project
  >
    <div class="featured-project__header">
      <span class="featured-project__title">{{ title|default('Project') }}</span>
      <span class="featured-project__arrow" aria-hidden="true">
        {# Inner span: GSAP animates this (transform on root SVG is unreliable). #}
        <span class="featured-project__arrow-motion" data-featured-arrow>
          <svg class="featured-project__arrow-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 7h6.5M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </span>
    </div>
    {% if image_src|default('') %}
      <div class="featured-project__media">
        <img
          class="featured-project__image"
          src="{{ image_src }}"
          alt="{{ image_alt|default('') }}"
          loading="lazy"
          width="1600"
          height="900"
        >
      </div>
    {% endif %}
    <span class="featured-project__cursor" aria-hidden="true">
      <span class="featured-project__cursor-text">{{ cursor_label }}</span>
    </span>
  </a>
</section>
