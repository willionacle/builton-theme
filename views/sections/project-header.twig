{#
  Project title block: centered post title + subtitle.
  Expects: title, subtitle.
#}
{% set heading_id = heading_id|default('project-header-title') %}
{% if title|default('') or subtitle|default('') %}
<section class="project-header" aria-labelledby="{{ heading_id }}">
  <div class="project-header__inner">
    {% if title|default('') %}
      <h1 id="{{ heading_id }}" class="project-header__title">{{ title }}</h1>
    {% endif %}
    {% if subtitle|default('') %}
      <p class="project-header__subtitle">{{ subtitle }}</p>
    {% endif %}
  </div>
</section>
{% endif %}
