{# Site logo: Customizer → Site Identity → Logo; falls back to site title text #}
<header class="site-header site-header--overlay">
  <div class="site-header__inner">
    <nav class="site-header__nav" aria-label="{{ __( 'Primary', 'builton' ) }}">
      {% if function('has_custom_logo') %}
        <div class="site-header__logo site-header__logo--custom">
          {{ function('get_custom_logo')|raw }}
        </div>
      {% else %}
        <a href="{{ site.url }}" class="site-header__logo site-header__logo--text" rel="home">
          <span class="site-header__logo-text">{{ site.name }}</span>
        </a>
      {% endif %}
      {% if function('has_nav_menu', 'primary') %}
        {{ function('wp_nav_menu', {
          'theme_location': 'primary',
          'menu_class': 'site-header__menu',
          'container': false,
          'echo': false
        }) }}
      {% else %}
        <ul class="site-header__menu">
          <li><a href="{{ site.url }}/what-we-do/">What we do</a></li>
          <li><a href="{{ site.url }}/projects/">Projects</a></li>
          <li><a href="{{ site.url }}/team/">Team</a></li>
          <li><a href="{{ site.url }}/contact/">Contact</a></li>
        </ul>
      {% endif %}
      <button type="button" class="site-header__hamburger" aria-label="{{ __( 'Open menu', 'builton' ) }}" aria-expanded="false" aria-controls="site-header__overlay">
        <span class="site-header__hamburger-line site-header__hamburger-line--1"></span>
        <span class="site-header__hamburger-line site-header__hamburger-line--2"></span>
        <span class="site-header__hamburger-line site-header__hamburger-line--3"></span>
      </button>
    </nav>
  </div>
  <div class="site-header__overlay" id="site-header__overlay" aria-hidden="true">
    <div class="site-header__overlay-inner">
      {% if function('has_nav_menu', 'primary') %}
        {{ function('wp_nav_menu', {
          'theme_location': 'primary',
          'menu_class': 'site-header__overlay-menu',
          'container': false,
          'echo': false
        }) }}
      {% else %}
        <ul class="site-header__overlay-menu">
          <li><a href="{{ site.url }}/what-we-do/">What we do</a></li>
          <li><a href="{{ site.url }}/projects/">Projects</a></li>
          <li><a href="{{ site.url }}/team/">Team</a></li>
          <li><a href="{{ site.url }}/contact/">Contact</a></li>
        </ul>
      {% endif %}
    </div>
  </div>
</header>
